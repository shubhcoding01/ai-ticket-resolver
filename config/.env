# ── Company ───────────────────────────────────────────
COMPANY_NAME=ICICI Bank
SUPPORT_NAME=IT Support Team
COMPANY_DOMAIN=icici.com
SUPPORT_EMAIL=itsupport@icici.com
TIMEZONE=Asia/Kolkata

# ── Freshdesk (DEMO — using mock) ─────────────────────
FRESHDESK_DOMAIN=demo.freshdesk.com
FRESHDESK_API_KEY=DEMO_KEY_NOT_REAL
POLL_INTERVAL_MINUTES=1
ESCALATION_AGENT_ID=0
ENGINEER_EMAIL=engineer@icici.com

# ── Claude AI (DEMO — using mock) ─────────────────────
ANTHROPIC_API_KEY=DEMO_KEY_NOT_REAL
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=500

# ── Automation ────────────────────────────────────────
AUTOMATION_ENABLED=true
POWERSHELL_PATH=powershell.exe
SCRIPT_TIMEOUT_SEC=120
DRY_RUN_MODE=true

# ── Email / SMTP (DEMO — notifications skipped) ───────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=demo@gmail.com
SMTP_PASSWORD=DEMO_PASSWORD
EMAIL_NOTIFICATIONS_ENABLED=false

# ── Knowledge Base ────────────────────────────────────
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_MAX_RESULTS=3
KB_MIN_SCORE=0.3

# ── Database ──────────────────────────────────────────
DB_PATH=database/tickets.db

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ── Dashboard ─────────────────────────────────────────
DASHBOARD_PORT=8501
DASHBOARD_CHART_DAYS=7

# ── Feature Flags ─────────────────────────────────────
FEATURE_AUTO_RESOLVE=true
FEATURE_KB_SEARCH=true
FEATURE_SENTIMENT_ANALYSIS=false
FEATURE_INTUNE_INTEGRATION=false
FEATURE_AFTER_HOURS_REPLY=true

# ── DEMO MODE ─────────────────────────────────────────
# DEMO_MODE=true
DEMO_TICKET_COUNT=10

# Run demo (no API keys needed)
DEMO_MODE=true

# Run live (real Freshdesk + Claude API)
# DEMO_MODE=false