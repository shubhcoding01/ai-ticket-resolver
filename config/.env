# ── Company ──────────────────────────────────────────
COMPANY_NAME=ICICI Bank
SUPPORT_NAME=IT Support Team
COMPANY_DOMAIN=icici.com
SUPPORT_EMAIL=itsupport@icici.com
SUPPORT_PHONE=1800-XXX-XXXX
TIMEZONE=Asia/Kolkata
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18

# ── Freshdesk ─────────────────────────────────────────
FRESHDESK_DOMAIN=yourcompany.freshdesk.com
FRESHDESK_API_KEY=your_freshdesk_api_key_here
POLL_INTERVAL_MINUTES=5
ESCALATION_AGENT_ID=0
ESCALATION_GROUP_ID=0
ENGINEER_EMAIL=engineer@icici.com

# ── Claude AI ─────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=500

# ── Automation ────────────────────────────────────────
AUTOMATION_ENABLED=true
POWERSHELL_PATH=powershell.exe
SCRIPT_TIMEOUT_SEC=120
DRY_RUN_MODE=false

# ── Intune / Azure (optional) ─────────────────────────
INTUNE_ENABLED=false
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Email / SMTP ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youremail@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMAIL_NOTIFICATIONS_ENABLED=true

# ── Knowledge Base ────────────────────────────────────
KB_CHUNK_SIZE=500
KB_CHUNK_OVERLAP=50
KB_MAX_RESULTS=3
KB_MIN_SCORE=0.3

# ── Database ──────────────────────────────────────────
DB_PATH=database/tickets.db

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ── Dashboard ─────────────────────────────────────────
DASHBOARD_PORT=8501
DASHBOARD_CHART_DAYS=7

# ── Feature Flags ─────────────────────────────────────
FEATURE_AUTO_RESOLVE=true
FEATURE_KB_SEARCH=true
FEATURE_SENTIMENT_ANALYSIS=false
FEATURE_TICKET_QUALITY_CHECK=false
FEATURE_INTUNE_INTEGRATION=false
FEATURE_AFTER_HOURS_REPLY=true